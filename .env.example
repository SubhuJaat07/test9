# REQUIRED - Must be set for each repo
REPO_ID=test1

# REQUIRED - Supabase credentials (same across all repos)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OPTIONAL - Workers per repo (default: 100)
WORKER_COUNT=100

# OPTIONAL - Self-ping URL to prevent sleeping (Render free tier)
# Set to your deployed URL, e.g., https://test1.onrender.com
SELF_PING_URL=

# OPTIONAL - Referral link (for reference)
REFERRAL_LINK=https://tpl.testbook.com/666924e1223228a0fdb907a1
